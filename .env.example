PORTFOLIO_ADMIN_SECRET=change-this-with-a-long-random-password

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_CONTENT_ROW_ID=primary

# AWS S3
AWS_S3_REGION=us-east-2
AWS_S3_BUCKET=bucket
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: only if you use a CDN/custom domain instead of the default S3 public URL
# AWS_S3_PUBLIC_BASE_URL=https://angelopol-portfolio.s3.us-east-2.amazonaws.com

# Optional: defaults to "portfolio"
# AWS_S3_KEY_PREFIX=portfolio
